# =============================================================================
# ML Network Anomaly Detection System — Environment Variables
# Copy this file to .env and fill in production values
# =============================================================================

# --- Flask Configuration ---
FLASK_APP=wsgi.py
FLASK_ENV=production
SECRET_KEY=change-this-to-a-long-random-string-in-production

# --- Database ---
DATABASE_URL=postgresql://anomaly_user:secure_password_here@localhost:5432/anomaly_detection
# For Docker Compose, use: postgresql://anomaly_user:secure_password_here@db:5432/anomaly_detection

# --- PostgreSQL (Docker) ---
POSTGRES_USER=anomaly_user
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=anomaly_detection

# --- Security ---
WTF_CSRF_ENABLED=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# --- File Upload ---
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# --- Rate Limiting ---
RATELIMIT_DEFAULT=200/hour
RATELIMIT_STORAGE_URL=memory://

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
